# =========================================================================
#  Multi-Tool AI Agent for Bangladesh — environment configuration
#  Copy this file to `.env` and fill in the values you need.
# =========================================================================

# --- Which LLM provider to use: google | groq | openai ---
LLM_PROVIDER=google

# --- Google Gemini (FREE tier) — get a key at https://aistudio.google.com/apikey ---
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# --- Groq (FREE tier) — get a key at https://console.groq.com/keys ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (optional, paid) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Web search: DuckDuckGo is used by default (NO key needed). ---
# Set a Tavily key to upgrade to higher-quality results automatically.
TAVILY_API_KEY=
